        "chapter_title": "Introduction",
        "paragraphs": [
          {
            "paragraph_number": "1.1",
            "summary": "This supervisory statement is addressed to all firms and to Lloyd’s. The statement should be read alongside the Insurance General Application Part of the Prudential Regulation Authority Rulebook. It e",
            "as_at_date": "01/01/2016"
          },
          {
            "paragraph_number": "1.2",
            "summary": "The PRA is publishing this statement to ensure that firms understand the requirements that they are expected to fulfil in order to comply with the PRA’s rules. It expands on the general approach as se",
            "as_at_date": "31/12/2024"
          },
          {
            "paragraph_number": "1.3",
            "summary": "This statement has been subject to public consultation and reflects the feedback that was received by the PRA.2",
            "as_at_date": "31/12/2024"
          }
        ]
      },
