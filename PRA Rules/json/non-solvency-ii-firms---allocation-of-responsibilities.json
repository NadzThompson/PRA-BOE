    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a small non-directive insurer.",
            "as_at_date": "07/03/2017"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "07/03/2017"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Allocation of Responsibilities",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must allocate each of the small non-directive insurer prescribed responsibilities to one or more persons who, in relation to that firm , are approved under section 59 of FSMA by eithe",
            "as_at_date": "07/03/2017"
          },
          {
            "rule_number": "2.2",
            "summary": "1. (1) A firm must have and maintain up-to-date records of the significant responsibilities allocated to each of those persons , including those allocated in accordance with [2.1](/pra-rules/non-s",
            "as_at_date": "07/03/2017"
          },
          {
            "rule_number": "2.3",
            "summary": "The firm must provide the PRA with a copy of the records in 2.2 upon request.",
            "as_at_date": "07/03/2017"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Prescribed Responsibilities",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Each of the responsibilities set out in this rule is a small non-directive insurer prescribed responsibility :",
            "as_at_date": "10/12/2018"
          }
        ]
      }
    ],
