    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a UK ISPV.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Solvency Requirements",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A UK ISPV must ensure that, subject to 2.1A at all times:",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.1A",
            "summary": "The requirements in 2.1 are subject to a grace period not exceeding 30 business days after the later of:",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.1B",
            "summary": "The requirements to be satisfied to apply the grace period referred to in 2.1A are:",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.2",
            "summary": "In order to be considered fully funded in accordance with 2.1, a UK ISPV must satisfy all of the following requirement",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.2A",
            "summary": "A UK ISPV may only use assets that are used to cover its aggregate maximum risk exposure under a risk transfer agreement (‘risk transfer A’) to cover all or part of its aggregate maximum risk exposure",
            "as_at_date": "23/12/2025"
          },
          {
            "rule_number": "2.2B",
            "summary": "The requirements in 2.2A(3) that assets are kept separate and are not co-mingled do not apply when there is a sole inv",
            "as_at_date": "23/12/2025"
          },
          {
            "rule_number": "2.3",
            "summary": "A UK ISPV must satisfy the requirements in 2.1 taking into account all of the following:",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.4",
            "summary": "The UK ISPV must:",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.5",
            "summary": "Payments relating to existing contracts of insurance and reinsurance contracts, that are expected to be received in the future by the UK ISPV from the undertaking that has transferred risk to the UK I",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "2.6",
            "summary": "A UK ISPV must invest all its assets in accordance with all of the following requirements:",
            "as_at_date": "31/12/2024"
          }
        ]
      },
