      {
        "chapter_number": "",
        "chapter_title": "Multi-arrangement Special Purpose Vehicles",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "This Chapter only applies to a multi-arrangement special purpose vehicle.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "4.2",
            "summary": "A multi-arrangement special purpose vehicle must be a UK protected cell company.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "4.2A",
            "summary": "The requirement in 4.2 does not apply where a multi-arrangement special purpose vehicle assumes risks under more than ",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "4.3",
            "summary": "A UK protected cell company must submit an assumption of risk notification using the new risk assumption notification form.",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "4.4",
            "summary": "A UK protected cell company must submit an inter-cell arrangement notification using the group of cells notification form.",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "4.5",
            "summary": "A multi-arrangement special purpose vehicle must be able to demonstrate to the PRA on request that its solvency cannot be adversely affected by the winding-up proceedings of any one of the undertaking",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "4.6",
            "summary": "When demonstrating that the multi-arrangement special purpose vehicle's solvency cannot be adversely affected by the winding-up proceedings of any one of the undertakings transferring risk to it, the ",
            "as_at_date": "24/07/2025"
          },
          {
            "rule_number": "4.7",
            "summary": "A multi-arrangement special purpose vehicle must be able to demonstrate to the PRA on request sufficient supporting evidence that it satisfies the conditions set out in [2.1](/pra-rules/insurance-spec",
            "as_at_date": "24/07/2025"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Restriction of Activities",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A UK ISPV must not engage in any activities other than insurance risk transformation and activities directly arising from insurance risk transformation.",
            "as_at_date": "08/12/2017"
          }
        ]
      },
      {
