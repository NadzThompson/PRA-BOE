    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to:",
            "as_at_date": "30/11/2022"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Management Expenses in Respect of Relevant Schemes Levy",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "This Chapter applies only to the FSCS.",
            "as_at_date": "03/07/2015"
          },
          {
            "rule_number": "2.2",
            "summary": "The FSCS may at any time impose a MERS levy on a firm or, where applicable, the Society provided that the FSCS has reasonable grounds for believing that the funds available to it to meet _re",
            "as_at_date": "30/11/2022"
          },
          {
            "rule_number": "2.3",
            "summary": "The FSCS can impose a MERS levy only if the FSCS has tried its best and has failed to obtain reimbursement of those expenses from the manager of the relevant scheme.",
            "as_at_date": "03/07/2015"
          },
          {
            "rule_number": "2.4",
            "summary": "The FSCS must calculate a share of a MERS levy for a firm or, where applicable, the Society , on a reasonable basis.",
            "as_at_date": "30/11/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Obligation to Pay",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm (and, where applicable, the Society) must pay to the FSCS its share of each MERS levy.",
            "as_at_date": "30/11/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Payments",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm (and, where applicable, the Society) must pay its share of a MERS levy in one payment.",
            "as_at_date": "30/11/2022"
          },
          {
            "rule_number": "4.2",
            "summary": "A share of a MERS levy is due on, and payable within, 30 days of the date when the invoice is issued.",
            "as_at_date": "12/10/2016"
          },
          {
            "rule_number": "4.3",
            "summary": "A firm (and, where applicable, the Society) must pay its share of a MERS levy by either direct debit, credit transfer (e.g. BACS or CHAPS), cheque, Maestro, Visa Debit or by credit card (Visa/Ma",
            "as_at_date": "30/11/2022"
          },
          {
            "rule_number": "4.4",
            "summary": "The FSCS may reduce, remit or refund any overpaid amounts paid in respect of a MERS levy in respect of a particular period, due to a mistake of law or fact by a firm or, where applicable, the _S",
            "as_at_date": "30/11/2022"
          },
          {
            "rule_number": "4.5",
            "summary": "If a firm (and, where applicable, the Society), does not pay the total amount of its share of a MERS levy , before the end of the date on which it is due, it must pay an additional amount as fol",
            "as_at_date": "30/11/2022"
          }
        ]
      }
    ],
