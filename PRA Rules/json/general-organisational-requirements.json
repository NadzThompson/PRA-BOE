    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a CRR firm:",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "1.1A",
            "summary": "2.1 to 2.8 do not appl",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.3",
            "summary": "In this Part, a reference to a provision of the Employment Rights Act 1996 includes a reference to the corresponding provision of the Employment Rights (Northern Ireland) Order 1996.",
            "as_at_date": "07/09/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "General Requirements",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must establish, implement and maintain robust governance arrangements and decision-making procedures, which include:",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.1A",
            "summary": "A firm must comply with the following organisational requirements:",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.2",
            "summary": "The arrangements, processes and mechanisms referred to in 2.1 and [2.1A](/pra-rules/general-organisational-requ",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.2A",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.2B",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.3",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.4",
            "summary": "A firm must establish, implement and maintain systems and procedures that are adequate to safeguard the security, integrity and confidentiality of information, taking into account the nature of the in",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must take reasonable steps to ensure continuity and regularity in the performance of its regulated activities. To this end the firm must employ appropriate and proportionate systems, reso",
            "as_at_date": "03/01/2018"
          },
          {
            "rule_number": "2.6",
            "summary": "A firm must establish, implement and maintain contingency and business continuity plans to ensure the firm’s ability to operate on an ongoing basis and limit losses in the event of severe business dis",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.6A",
            "summary": "A firm must establish, implement and maintain an adequate business continuity policy aimed at ensuring, in the case of an interruption to its systems and procedures, the preservation of essential data",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.7",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.7A",
            "summary": "A firm must establish, implement and maintain accounting policies and procedures and ensure that, upon the request of the PRA, it is able to deliver in a timely manner to the PRA financial reports whi",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.8",
            "summary": "A firm must monitor and, on a regular basis, evaluate the adequacy and effectiveness of its systems, internal control mechanisms and arrangements established in accordance with this [Chapter](/pra-r",
            "as_at_date": "03/01/2018"
          },
          {
            "rule_number": "2.9",
            "summary": "[Deleted.]",
            "as_at_date": "07/09/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Whistleblowing",
        "rules": []
      },
      {
        "chapter_number": "",
        "chapter_title": "Persons Who Effectively Direct the Business",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "The senior personnel of a firm must be of sufficiently good repute and sufficiently experienced as to ensure the sound and prudent management of the firm.",
            "as_at_date": "03/01/2018"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm must ensure that its management is undertaken by at least two persons meeting the requirements laid down in [3.1](/pra-rules/general-organisational-requirements#6c8777e4d09a47a0818cc1f89fbc97",
            "as_at_date": "03/01/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Responsibility of Senior Personnel",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.1A",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.1B",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.2",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.3",
            "summary": "A firm must ensure that, when allocating functions internally, senior management and, where applicable, the governing body are responsible for ensuring that the firm complies with its obligations unde",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.4",
            "summary": "A firm must ensure that senior management and, where applicable, the governing body assess and periodically review the effectiveness of the policies, arrangements and procedures put in place to comply",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.5",
            "summary": "In its allocation of significant functions among senior managers, a firm must clearly establish who is responsible for overseeing and maintaining the firm's organisational requirements.",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.6",
            "summary": "A firm must keep its records of the allocation of significant functions up-to-date.",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.7",
            "summary": "A firm must ensure that its senior management receive on a frequent basis, and at least annually, written reports on the matters covered by the [Compliance and Internal Audit](/pra-rules/compliance-an",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "4.8",
            "summary": "A firm must ensure that, for the purposes of 4.3 and [4.4](/pra-rules/general-organisational-requirements#efb93cc2da1",
            "as_at_date": "23/10/2025"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Management Body",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A firm must ensure that the management body defines, oversees and is accountable for the implementation of governance arrangements that ensure effective and prudent management of the firm , incl",
            "as_at_date": "03/01/2018"
