      {
        "chapter_number": "",
        "chapter_title": "Calculation of Technical Provisions",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Firms must establish adequate technical provisions with respect to all of their insurance and reinsurance obligations towards policyholders.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "The value of technical provisions must correspond to the current amount that the firm would have to pay if it were to transfer its insurance and reinsurance obligations immediately to another _U",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "2.3",
            "summary": "Firms must calculate their technical provisions :",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "The value of technical provisions must be equal to the sum of a best estimate and a risk margin which must be calculated in accordance with [2.5](/pra-rules/technical-provisions#e388d61285c94e15",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.5",
            "summary": "1. (1) Firms must value the best estimate and the risk margin separately, except where (2) applies.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Best Estimate",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "The best estimate must:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "3.2",
            "summary": "The cash-flow projection used in the calculation of the best estimate (whether valued separately or determined on the basis of financial instruments in accordance with [2.5](/pra-rules/technical-pro",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Risk Margin",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "Where firms value the best estimate and risk margin separately, the risk margin must be an amount equal to the cost that a UK Solvency II firm would incur in order to hold _eligible own fund",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "4.2",
            "summary": "The risk margin must be such as to ensure that the value of the technical provisions is equivalent to the amount that a UK Solvency II firm would be expected to require in order to take over and",
            "as_at_date": "31/12/2020"
          }
        ]
      },
