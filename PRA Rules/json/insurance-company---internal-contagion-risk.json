    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a non-directive insurer , other than a non-directive friendly society.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part applies to the whole of the firm's business carried on world-wide.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Restriction of Business",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm other than a pure reinsurer must not carry on any commercial business other than insurance business and activities directly arising from that business.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "A pure reinsurer must not carry on any business other than the business of reinsurance and related operations.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Financial Limitation of Non-Insurance Activities",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must limit, manage and control its non-insurance activities so that there is no significant risk arising from those activities such that it may be unable to meet its liabilities as they fall ",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Separately Identify and Maintain Long-Term Insurance Assets",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm carrying on long-term insurance business must identify the assets relating to its long-term insurance business which it is required to hold by virtue of:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "4.2",
            "summary": "1. (1) A firm's long-term insurance assets are the items in (2), adjusted to take account of:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "4.3",
            "summary": "1. (1) Unless (2) applies, all the long-term insurance assets of the firm constitute its long-term insurance fund.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "4.4",
            "summary": "A firm must maintain a separate accounting record in respect of each of its long-term insurance funds.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "4.5",
            "summary": "A firm may not transfer assets out of a long-term insurance fund unless:",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Exclusive Use of Long-Term Insurance Assets",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "1. (1) A firm must apply a long-term insurance asset only for the purposes of its long-term insurance business.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "5.2",
            "summary": "A firm must not agree to, or allow, any mortgage or charge on its long-term insurance assets other than in respect of a long-term insurance liability.",
            "as_at_date": "01/01/2016"
          }
        ]
      }
    ],
    "section_count": 5,
