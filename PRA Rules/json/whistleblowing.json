    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to:",
            "as_at_date": "07/09/2017"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.3",
            "summary": "In this Part, a reference to a provision of the Employment Rights Act 1996 includes a reference to the corresponding provision of the Employment Rights (Northern Ireland) Order 1996.",
            "as_at_date": "07/09/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Whistleblowing",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must establish, maintain and implement appropriate and effective arrangements for the disclosure of reportable concerns by a person , including a firm’s employee , internally through ",
            "as_at_date": "07/09/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "The channel in 2.1 may be provided through arrangements with third parties, including social partners, subject to any applicable req",
            "as_at_date": "07/09/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm must inform all workers of the channel referred to in 2.1.",
            "as_at_date": "07/09/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "A firm must inform all workers :",
            "as_at_date": "07/09/2016"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must ensure that nothing in its arrangements prevents or discourages any worker from making any disclosure to the PRA or the FCA before making the disclosure through the channel referre",
            "as_at_date": "07/09/2017"
          },
          {
            "rule_number": "2.6",
            "summary": "A firm must ensure that nothing in any employment contract or settlement agreement, including any other related or ancillary documentation, between the firm and a worker relating to the _worker’",
            "as_at_date": "07/09/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Lloyds",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "This Part applies to the Society and managing agents separately.",
            "as_at_date": "07/09/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Third Country Branches",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "This Chapter only applies to a third country branch undertaking.",
            "as_at_date": "07/09/2017"
          },
          {
            "rule_number": "4.2",
            "summary": "2.1 to 2.3 and [2.5](/pra-rules/whistleblowing#8c300900bfcf4e1f8",
            "as_at_date": "07/09/2017"
          },
          {
            "rule_number": "4.3",
            "summary": "2.4 applies only in relation to a third country branch undertaking’s workers in the UK.",
            "as_at_date": "07/09/2017"
          }
        ]
      }
