        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to Article 109 undertakings and references to a firm in Chapters 2-[4](/pra-rules/capital-buffers#97ed",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.1A",
            "summary": "[Deleted.]",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.3",
            "summary": "Unless otherwise defined, any italicised expression used in this Part and in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/05/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Capital Conservation Buffer",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must calculate a capital conservation buffer of common equity tier 1 capital equal to 2.5% of its total risk exposure amount.",
            "as_at_date": "31/03/2025"
          },
          {
            "rule_number": "2.2",
            "summary": "[Deleted]",
            "as_at_date": "31/03/2025"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Countercyclical Capital Buffer",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "1. (1) A firm must calculate a countercyclical capital buffer of common equity tier 1 capital equal to its total risk exposure amount multiplied by its _institution-specific countercyclical ca",
            "as_at_date": ""
          },
          {
            "rule_number": "3.2",
            "summary": "[Deleted.]",
            "as_at_date": "31/12/2020"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Capital Conservation Measures",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm does not meet the combined buffer if the common equity tier 1 capital maintained by the firm which is not used to meet the Pillar 1 requirements or any Pillar 2A requirement does not meet the c",
            "as_at_date": "31/03/2025"
          },
          {
            "rule_number": "4.2",
            "summary": "[Deleted]",
            "as_at_date": "31/03/2025"
          },
          {
            "rule_number": "4.3",
            "summary": "1. (1) A firm that does not meet the combined buffer must:",
            "as_at_date": ""
          },
          {
            "rule_number": "4.4",
            "summary": "When a firm does not meet the combined buffer , it must prepare a capital conservation plan and submit it to the PRA no later than 5 working days after the firm identified that it did not meet",
            "as_at_date": "01/05/2014"
          },
          {
            "rule_number": "4.5",
            "summary": "The capital conservation plan must include the following:",
            "as_at_date": "01/05/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Application on an Individual and Consolidated Basis",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "This Part applies to a firm on an individual basis whether or not it also applies to the firm on a consolidated basis or sub-consolidated basis.",
            "as_at_date": "01/05/2014"
          },
          {
            "rule_number": "5.1A",
            "summary": "If this Part applies to a firm on an individual basis, the firm must comply with the rules in this Part to the same extent and in the same manner as it is required to comply with the firm’s obligation",
            "as_at_date": "31/03/2025"
          },
          {
            "rule_number": "5.2",
            "summary": "A firm which is a UK parent institution must comply with this Part on the basis of its consolidated situation.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "5.3",
            "summary": "A PRA approved parent holding company , a PRA designated parent holding company , a PRA designated intermediate holding company or a PRA designated institution responsible for meeting CRR requ",
            "as_at_date": "29/12/2020"
          },
          {
            "rule_number": "5.4",
            "summary": "[Deleted.]",
            "as_at_date": "29/12/2020"
          },
          {
            "rule_number": "5.5",
            "summary": "[Deleted.]",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "5.6",
            "summary": "If this Part applies to an Article 109 undertaking on a consolidated basis or on a sub-consolidated basis, the Article 109 undertaking must carry out consolidation to the same extent and in the same m",
            "as_at_date": "31/03/2025"
          }
        ]
      }
