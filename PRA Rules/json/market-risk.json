        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to:",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.1A",
            "summary": "1. (1) a firm must comply with this Part on an individual basis.",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.3",
            "summary": "Unless otherwise defined, any italicised expression used in this Part and defined in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/01/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Use of Internal Models: Risk Capture",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm which has a permission to use internal models in accordance with Title IV, Chapter 5 of the CRR :",
            "as_at_date": "01/01/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Netting: Convertible Bonds",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "For the purposes of Article 327(2) of the CRR , the netting of a convertible bond and an offsetting position in the instrument underlying is permitted. The convertible bond shall be:",
            "as_at_date": "01/01/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Instruments for Which No Treatment Specified",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "Where a firm has a position in a financial instrument for which no treatment has been specified in the CRR , it must calculate its own funds requirement for that position by applying the most ",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm must document its policies and procedures for calculating own funds for such positions in its trading book policy statement.",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.3",
            "summary": "If there are no appropriate treatments the firm must calculate an own funds requirement of an appropriate percentage of the current value of the position. An appropriate percentage is either 100%,",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.4",
            "summary": "For the purposes of this rule, trading book policy statement means the statement of policies and procedures relating to the trading book.",
            "as_at_date": "01/01/2014"
          }
        ]
      }
