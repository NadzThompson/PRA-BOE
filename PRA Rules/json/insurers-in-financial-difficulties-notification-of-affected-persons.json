    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to every insurer under write-down but not to affected market participants or the Society.",
            "as_at_date": "19/09/2023"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Affected Persons",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "For the purposes of section 377F(3) of FSMA , an affected person in relation to an insurer under write-down is:",
            "as_at_date": "19/09/2023"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Specified Information",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "For the purposes of section 377F(4)(a) of FSMA , the following information is specified:",
            "as_at_date": "19/09/2023"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Form and Manner of Notification",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "For the purposes of section 377F(4)(b) of FSMA , this Chapter specifies the form and manner in which specified information must be given.",
            "as_at_date": "19/09/2023"
          },
          {
            "rule_number": "4.2",
            "summary": "Specified information may be provided in different packs for different purposes, with each such pack containing only such information as is relevant to the intended recipient. This may include:",
            "as_at_date": "19/09/2023"
          },
          {
            "rule_number": "4.3",
            "summary": "Specified information must be given in writing in English on paper or another format available and accessible to the affected person , provided that:",
            "as_at_date": "19/09/2023"
          },
          {
            "rule_number": "4.4",
            "summary": "An affected person is entitled, upon request and without charge, to receive specified information on paper. An affected person is also entitled to change the means of communication used.",
            "as_at_date": "19/09/2023"
          },
          {
            "rule_number": "4.5",
            "summary": "Copies of specified information must also be available on a website, and:",
            "as_at_date": "19/09/2023"
          }
        ]
      }
    ],
