    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to:",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "A firm that is neither a subsidiary of a parent undertaking incorporated in or formed under the law of any part of the UK nor a parent undertaking must comply with this Part on an individual",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.3",
            "summary": "A firm that is not a member of a consolidation group must comply with this Part on an individual basis.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.4",
            "summary": "[deleted.]",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.5",
            "summary": "[deleted.]",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.5A",
            "summary": "A CRR consolidation entity must comply with this Part on a consolidated basis , and for that purpose, references to a firm in this Part (other than in [1.1](/pra-rules/reporting-pillar-2/03-03-2",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.6",
            "summary": "In this Part the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Pillar 2 Reporting Requirements",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must complete the data item FSA071 for the risk assessments required in the ICAA Part.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "A firm must complete the data items FSA078 and FSA079 for concentration risk.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "A significant firm and any firm that is not significant but that has permission from the PRA to use the Advanced Measurement Approach must complete the data items FSA072, FSA073, FSA074 and ",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "A firm with significant illiquid risk in its trading book must complete the data item FSA080 for market risk, unless the data required in that data item has already been reported to the PRA by",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm with permission from the PRA to use the IRB Approach for retail claims or contingent retail claims must complete the data item FSA082 for credit risk that relates to the IRB Approach ",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.6",
            "summary": "A firm with a defined benefit pension scheme must complete the data item FSA081 for pension obligation risk, unless the data required in that data item has already been reported to the PRA b",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.7",
            "summary": "A firm must complete the data item FSA076 for any wholesale portfolio of exposures for which capital requirements are calculated using the Standardised Approach to credit risk.",
            "as_at_date": "01/01/2018"
          },
          {
            "rule_number": "2.8",
            "summary": "A firm must complete the data item FSA077 for any retail portfolio of exposures for which capital requirements are calculated using the Standardised Approach to credit risk.",
            "as_at_date": "01/01/2018"
          },
          {
            "rule_number": "2.9",
            "summary": "A firm with total assets equal to or greater than £5 billion at the relevant level of consolidation used as the basis of its ICAAP must complete the data item PRA111.",
            "as_at_date": "01/10/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Submission",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must submit the data items it is required to complete by this Part to the PRA at the same time as the firm submits its ICAAP assessment to the PRA.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm that does not submit an ICAAP assessment to the PRA on an annual basis must submit the data items it is required to complete by this Part to the PRA on a regular basis that is proport",
            "as_at_date": "01/10/2018"
          },
          {
            "rule_number": "3.3",
            "summary": "Data items must be submitted to the PRA by electronic means.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "3.4",
            "summary": "When submitting the required data item , a firm must use the template for the data item set out in _[Chapter 4](/pra-rules/reporting-pillar-2/03-03-2026#193aed7efd104ad6bc9906cd79b49fef \"Chapter",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
