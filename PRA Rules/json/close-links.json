    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to every firm.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Requirement to Notify Changes in Close Links",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must notify (or procure that another firm in its group notifies) the PRA that it has begun to have or ceased to have close links with any person.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.2",
            "summary": "Where a firm has elected to report changes in close links on a monthly basis under 3.1, it must:",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.3",
            "summary": "The Close Links Monthly Report must include the information specified in the form.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.4",
            "summary": "Where a firm has not elected to report changes in close links on a monthly basis under 3.1, it must make (or procure that another _",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.5",
            "summary": "The notification submitted under 2.4 must be made by completing the Close Links Notification Form and must include all the relevant i",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Election to Notify Changes in Close Links on a Monthly Basis",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm wishing to report changes in close links on a monthly basis must send a written notice of election to the firm’s usual supervisory contact at the PRA.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm wishing to cease reporting changes in close links on a monthly basis must send a written notice of that intention to its usual supervisory contact at the PRA at least one month before chang",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Annual Close Links Report",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm must submit (or procure that another firm in its group submits) annually by electronic means to the PRA the Close Links Annual Report , within four months of the firm’s _accounting ",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "4.2",
            "summary": "An unincorporated friendly society is only required to submit a report under 4.1 if it is aware that it has close links.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "4.3",
            "summary": "The Close Links Annual Report must include the information specified in the form.",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Forms",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "The Close Links Notification Form can be found [here](https://www.bankofengland.co.uk/-/media/boe/files/prudential-regulation/regulatory-reporting/banking/close-links-notification-form-dec18.xls \"Cl",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "5.2",
            "summary": "The Close Links Monthly Report can be found [here](https://www.bankofengland.co.uk/-/media/boe/files/prudential-regulation/regulatory-reporting/banking/rep001atemplatedec18.pdf \"Close Links Monthly ",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "5.3",
            "summary": "The Close Links Annual Report can be found [here](https://www.bankofengland.co.uk/-/media/boe/files/prudential-regulation/regulatory-reporting/banking/rep001templatedec18.pdf \"Close Links Annual Rep",
