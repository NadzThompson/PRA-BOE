    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "1.3",
            "summary": "Unless otherwise defined, any italicised expression used in this Part and in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "1.4",
            "summary": "Interpretation 2.13 does not apply to this Part.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Level of Application",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must comply with this Part on an individual basis.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.2",
            "summary": "2.1 does not apply where the firm is a member of a consolidation group.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.3",
            "summary": "A CRR consolidation entity must comply with this Part on the basis of its consolidated situation.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.4",
            "summary": "For the purposes of 2.3 and 2.6, references to a firm in this Part (other than i",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm that is required to comply with Parts Two and Three of the CRR on a sub-consolidated basis shall comply with this Part on the same basis.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.6",
            "summary": "A CRR consolidation entity that is required to comply with Parts Two and Three of the CRR on a sub-consolidated basis shall comply with this Part on the same basis.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Managing Step-in Risk",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must identify, monitor and manage step-in risk.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm must take all reasonable steps to mitigate significant step-in risk in respect of its material step-in entities.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Strategies, Processes and Systems",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm must have in place sound, effective and comprehensive strategies, processes and systems that enable it to comply with 3.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "4.2",
            "summary": "The strategies, processes and systems required by 4.1 must be proportionate to the nature, scale and complexity of the firm’s activities.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Step-in Risk Assessment",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A firm must prepare and regularly update its step-in risk assessment.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Identification of Step-in Entities",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "A firm must identify:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "6.2",
            "summary": "For the purpose of complying with 6.1, a firm is not required to identify a relationship with an SSPE where:",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Assessment of Material Step-in Entities",
        "rules": [
          {
            "rule_number": "7.1",
            "summary": "A firm must assess whether step-in risk in respect of its material step-in entities is significant.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "7.2",
            "summary": "When undertaking the assessment required by 7.1, a firm must consider at least:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "7.3",
            "summary": "A firm must assess the potential impact on the firm of providing financial support to a material step-in entity were step-in risk to materialise.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Step-in Risk Policy",
        "rules": [
          {
            "rule_number": "8.1",
            "summary": "A firm must document its policies and procedures for assessing step-in risk.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "8.2",
            "summary": "A firm’s step-in risk policy must:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "8.3",
            "summary": "The content and level of detail of a firm’s step-in risk policy must be proportionate to the nature, scale and complexity of the firm’s activities.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "8.4",
            "summary": "A firm’s step-in risk policy must be reviewed:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "8.5",
            "summary": "A firm must be able to provide to the PRA on request a current version of its step-in risk policy, together with all versions that applied during the preceding three years.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Governance",
        "rules": [
          {
            "rule_number": "9.1",
            "summary": "A firm must ensure that its management body approves its step-in risk assessment.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "9.2",
            "summary": "A firm must ensure that its management body approves its step-in risk policy.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Reporting",
        "rules": [
          {
            "rule_number": "10.1",
            "summary": "A firm must submit the data items representing its step-in risk assessment to the PRA in accordance with the applicable requirements in the Regulatory Reporting Part",
            "as_at_date": "01/01/2026"
          }
        ]
      }
    ],
