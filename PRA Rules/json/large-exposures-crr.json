    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to:",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.3",
            "summary": "For the purposes of calculating the value of exposures in accordance with this Part the term ‘institution’ shall include a private or public undertaking , including its branches, which, were it es",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "1.4",
            "summary": "For the purposes of Chapter 5 Part\") of this Part the following definitions shal",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Level of Application",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must comply with this Part on an individual basis.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.2",
            "summary": "Where a firm has been given permission under Article 9(1) of  CRR it must incorporate relevant subsidiaries in the calculation undertaken to comply with rule [2.1](/pra-rules/large-exposures-crr/03-",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.3",
            "summary": "But rule 2.1 does not apply to the second and third paragraphs of [Article 394(1)](/pra-rules/large-exposures-crr/03",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.4",
            "summary": "A CRR consolidation entity must comply with this Part on the basis of its consolidated situation.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.5",
            "summary": "For the purposes of applying this Part on a consolidated basis, the terms ‘firm’, ‘institution’ and ‘UK parent institution’ include a CRR consolidation entity (if it would not otherwise have been in",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.6",
            "summary": "The expression ‘consolidated situation’ applies for the purposes of this Part as it does for the purposes of Parts Two and Three of  CRR.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.7",
            "summary": "A firm that is required to comply with Parts Two and Three of  CRR on a sub-consolidated basis, must comply with this Part on the same basis.",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Organisational Structure and Control Mechanisms",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A CRR consolidation entity and a firm must set up a proper organisational structure and appropriate internal control mechanisms in order to ensure that the data required for consolidation for the ",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "3.2",
            "summary": "A CRR consolidation entity and a firm must ensure that a subsidiary not subject to this Part implements arrangements, processes and mechanisms to ensure proper consolidation for the purposes of this",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "3.3",
            "summary": "A firm must monitor and control its large exposures in accordance with this Part.",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "3.4",
            "summary": "A firm must have sound administrative and accounting procedures and adequate internal control mechanisms for the purposes of identifying, managing, monitoring, reporting and recording all large exposu",
            "as_at_date": "01/01/2026"
          }
        ]
      },
