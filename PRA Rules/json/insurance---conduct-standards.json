        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Individual Conduct Standard 1: You must act with integrity.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "Individual Conduct Standard 2: You must act with due skill, care and diligence.",
