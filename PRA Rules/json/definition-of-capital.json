    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to:",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.1A",
            "summary": "1. (1) A CRR firm must comply with this Part on an individual basis and as applicable on a sub-consolidated basis.",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part the following definitions shall apply:",
            "as_at_date": "01/04/2020"
          },
          {
            "rule_number": "1.3",
            "summary": "Unless otherwise defined, any italicised expression used in this Part and in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/01/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Holdings of Own Funds Instruments Issued by Financial Sector Entities Included in the Scope of Consolidated Supervision",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "For the purposes of calculating own funds on an individual basis and a sub-consolidated basis , firms subject to supervision on a consolidated basis must deduct holdings of _own funds instrume",
            "as_at_date": "01/04/2020"
          },
          {
            "rule_number": "2.2",
            "summary": "[Deleted.]",
            "as_at_date": "01/04/2020"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm must not apply the deduction in 2.1 to its holdings of own funds instruments issued by a venture capital investor ",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.4",
            "summary": "For the purposes of this Chapter, a venture capital investor is a financial institution , in relation to which:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.5",
            "summary": "For the purposes of this Chapter, a venture capital investment is a designated investment which, at the time the investment is made, is:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.6",
            "summary": "For the purposes of this Chapter, a designated investment is a security or contractually-based investment specified in Articles 76 to 85 and 89 of the Financial Services and Markets Act 2000 (Regulate",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.7",
            "summary": "A firm must not apply the deduction in 2.1 to that percentage of its holdings of own funds instruments issued by a ventur",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.8",
            "summary": "For the purposes of this Chapter, a venture capital holding company is a financial institution , in respect of which:",
            "as_at_date": "01/01/2014"
          }
        ]
      },
