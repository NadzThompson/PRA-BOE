        "chapter_number": "",
        "chapter_title": "Connected Funding of a Capital Nature",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "[Deleted.]",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm must not avoid the requirements of the CRR by structuring its investments as connected funding of a capital nature.",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.3",
            "summary": "A firm must treat all connected funding of a capital nature as a holding of capital of the connected party and apply to it the treatment under the CRR and the PRA Rulebook applicable to such a hol",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.4",
            "summary": "If the connected party is a financial sector entity , the firm must treat the connected funding of a capital nature as a holding of Common Equity Tier 1 instruments ,_Additional Tier 1 instrumen",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.5",
            "summary": "A firm must report to the PRA all connected funding of a capital nature at least one month in advance of entry into the relevant funding transaction and identify each relevant transaction with s",
            "as_at_date": "01/04/2020"
          },
          {
            "rule_number": "4.6",
            "summary": "A loan or other funding transaction is connected funding of a capital nature if it is made by the firm to a connected party and:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.7",
            "summary": "A loan or other funding transaction is connected funding of a capital nature if it:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.8",
            "summary": "A guarantee is connected funding of a capital nature if it is a guarantee by the firm of a loan or other funding transaction from a third party to a connected party of the firm and:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.9",
            "summary": "For the purposes of this Chapter and in relation to a firm , a connected party means another person (“P”) in respect of whom the firm has not been permitted to apply the individual consolidation m",
            "as_at_date": "31/03/2015"
          },
          {
            "rule_number": "4.10",
            "summary": "For the purposes of 4.9(1), a firm and another person are closely related when:",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "4.11",
            "summary": "For the purposes of 4.9(2), a person is an associate of a firm if it is:",
            "as_at_date": "01/04/2020"
          }
        ]
