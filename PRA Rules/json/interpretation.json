          },
          {
            "rule_number": "2.9",
            "summary": "1. (1) Unless the contrary intention appears any reference in these rules to any provision of:",
            "as_at_date": "01/01/2026"
          },
          {
            "rule_number": "2.10",
            "summary": "1. (1) Subject to paragraph (3), CRR restatement provisions shall apply as their corresponding provisions would have applied in accordance with the direction made by the Prudential Regulation Author",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "2.11",
            "summary": "Any reference in CRR rules or rules made under section 192XA FSMA to the granting of a waiver, approval, permission or other form of consent by the competent authority is a reference to the givi",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "2.12",
            "summary": "Nothing in the CRR , or in an instrument made under the CRR , shall prevent or otherwise restrict, expressly or impliedly, the making of:",
            "as_at_date": "01/01/2022"
