          },
          {
            "rule_number": "2.6",
            "summary": "If a firm is dissolved, but its authorisation continues to have effect under section 32 (Partnerships and unincorporated associations) of FSMA in relation to any partnership or unincorporated asso",
            "as_at_date": "01/01/2014"
          },
          {
            "rule_number": "2.7",
            "summary": "Unless the context otherwise requires, any reference in these rules to:",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "2.8",
            "summary": "1. (1) The PRA Rulebook shall, after IP completion day , be construed, unless the contrary intention appears, as conferring rights and imposing obligations in relation to or in connection with Gibra",
