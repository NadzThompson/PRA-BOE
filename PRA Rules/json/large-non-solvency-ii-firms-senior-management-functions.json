            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "9.2",
            "summary": "The Chief Underwriting Officer function (SMF23) is the function of having responsibility, in respect of the firm's general insurance business, for the underwriting decisions in respect of material",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Combination of Senior Management Functions",
        "rules": [
          {
            "rule_number": "10.1",
            "summary": "This Chapter does not apply to a Swiss general insurer.",
