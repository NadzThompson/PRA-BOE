      },
      {
        "chapter_number": "",
        "chapter_title": "Executive",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "The Chief Executive function (SMF1) is the function of having responsibility, under the immediate authority of the governing body , alone or jointly with others, for carrying out the management of",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.2",
            "summary": "The Chief Finance function (SMF2) is the function of having responsibility for the management of the financial resources of a firm and reporting to the governing body of a firm in relation to ",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.3",
            "summary": "The Chief Risk function (SMF4) is the function of having responsibility for overall management of the risk management system specified in [Non-Solvency II Firms – Governance 3.5](/pra-rules/non-solv",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.4",
            "summary": "The Head of Internal Audit function (SMF5) is the function of having responsibility for the management of the internal audit function specified in [Non-Solvency II Firms – Governance 9](/pra-rules",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.5",
            "summary": "The Head of Key Business Area function (SMF6) is the function of having responsibility for management of a business area or division of a firm (other than a third country branch undertaking) whe",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.6",
            "summary": "For the purposes of 3.5, the gross total assets and technical provisions of the business ",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.7",
            "summary": "The Chief Operations function (SMF24) is the function of having responsibility for the internal operations and technology of a firm.",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Oversight",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "The Chair of the Governing Body function (SMF9) is the function of having responsibility for chairing, and overseeing the performance of the governing body of a firm.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.2",
            "summary": "The Chair of Risk Committee function (SMF10) is the function of having responsibility for chairing, and overseeing the performance of any committee responsible for the oversight of the risk manageme",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.3",
            "summary": "The Chair of Audit Committee function (SMF11) is the function of having responsibility for chairing and overseeing the performance of any committee responsible for the oversight of the internal audi",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.4",
            "summary": "The Chair of Remuneration Committee function (SMF12) is the function of having responsibility for chairing and overseeing the performance of any committee responsible for the oversight of the design",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.5",
            "summary": "The Senior Independent Director function (SMF14) is the function of performing the role of a senior independent director , and having particular responsibility for leading the assessment of perfor",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Group Entities",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "The Group Entity Senior Manager function (SMF7) is the function of having a significant influence on the management or conduct of one or more aspects of the affairs of a firm in relation to its _r",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Head of Third Country Branch",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "This Chapter applies only to a Swiss general insurer.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "6.2",
            "summary": "The Head of Third Country Branch function (SMF19) is the function of having responsibility for the conduct of all activities of the Swiss general insurer that are subject to the _regulatory system",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "6.3",
            "summary": "1. (1) A Swiss general insurer must have at least one person approved to perform the Head of Third Country Branch function.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "6.4",
            "summary": "A Swiss general insurer is not required to have any person(s) approved to perform any of the other PRA senior management functions.",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Chief Actuary",
        "rules": [
          {
