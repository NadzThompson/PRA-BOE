    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a firm that is a UK bank or building society that, on the firm’s last accounting reference date , had retail deposits equal to or greater than",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "01/08/2019"
          },
          {
            "rule_number": "1.3",
            "summary": "Unless the contrary intention appears, all words and expressions used in this Part and in the CRR shall have the same meaning as in the CRR.",
            "as_at_date": "01/08/2019"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Assessment",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must carry out an adequate assessment of its preparations for resolution.",
            "as_at_date": "01/08/2019"
          },
          {
            "rule_number": "2.2",
            "summary": "The assessment in 2.1 must:",
            "as_at_date": "01/08/2019"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Report",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must submit to the PRA a report in writing of the assessment in 2.1 on a periodic basis.",
            "as_at_date": "10/01/2025"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm must submit to the PRA an updated version of the report in 3.1 within twenty working days of a change in the ass",
            "as_at_date": "01/08/2019"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Disclosure",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm must publish a summary of the most recent report submitted to the PRA under Chapter 3 on a periodic basis.",
            "as_at_date": "10/01/2025"
          }
        ]
      }
    ],
