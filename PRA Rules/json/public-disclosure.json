        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to every firm that is a CRR firm.",
            "as_at_date": "12/10/2016"
          },
          {
            "rule_number": "1.2",
            "summary": "[Deleted.]",
            "as_at_date": "01/01/2022"
          },
          {
            "rule_number": "1.3",
            "summary": "Unless otherwise defined, any italicised expression used in this Part and in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Public Disclosure of Return on Assets",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must disclose in its annual report and accounts among the key indicators their return on assets, calculated as their net profit divided by their total balance sheet.",
