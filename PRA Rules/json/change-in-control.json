        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "1. (1) Unless otherwise stated, this Part applies to every firm except:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Obligations on Controllers and Proposed Controllers",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "The PRA directs that a section 178 notice submitted to the PRA in accordance with section 178(1) of FSMA must contain the information and be accompanied by such documents as are required by th",
            "as_at_date": "19/01/2019"
          },
          {
            "rule_number": "2.2",
            "summary": "1. (1) The PRA directs that a person who has submitted a section 178 notice must notify the PRA immediately if the person becomes aware, or has information which reasonably suggests, that th",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.3",
            "summary": "The PRA directs that a notice under section 191D of FSMA must provide details of the extent of control (if any) that the controller will have following the change in control.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "2.4",
            "summary": "Where a controller or proposed controller that is an investment manager is complying with the directions in 2.1 and [2.3](/",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Obligations on Firms",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A UK domestic firm , other than a non-directive firm or a building society , must notify the PRA of:",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.2",
            "summary": "A building society or a non-directive firm must notify the PRA of:",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.3",
            "summary": "An overseas firm must notify the PRA of:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "3.4",
            "summary": "The notifications in 3.1 to 3.3 must:",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.6",
            "summary": "1. (1) A UK domestic firm must notify the PRA immediately if, in the period between a section 178 notice being submitted and the occurrence of the change in control , the firm becomes aware,",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.7",
            "summary": "During the period referred to in 3.6, a UK domestic firm must take reasonable steps to keep itself informed about the circumsta",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.8",
            "summary": "A firm must notify the PRA :",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "3.9",
            "summary": "The notification under 3.8 must be given within 14 days of the change in control or of having the grounds (as applicable).",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Ongoing Notification Requirements",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm must notify the PRA as soon as it becomes aware of any of the following matters in respect of one or more of its controllers :",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm must take reasonable steps to keep itself informed about controllers , including if applicable:",
            "as_at_date": "03/08/2015"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Annual Controllers Report",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A firm must submit (or procure that another firm in its group submits) to the PRA , by electronic means, a completed Annual Controllers Report , within four months of the firm's _accounting ",
            "as_at_date": "19/01/2019"
          },
          {
            "rule_number": "5.2",
            "summary": "A mutual or a building society is only required to submit a report under 5.1 if it is aware that it has a controller.",
            "as_at_date": "01/09/2018"
          },
          {
            "rule_number": "5.3",
            "summary": "In relation to a building society , a controller does not include a person who is exempt from the obligation to notify a change in control under the Exemption Order.",
            "as_at_date": "03/08/2015"
          },
          {
            "rule_number": "5.4",
            "summary": "An insurer need not submit a report under 5.1 to the extent that the information has already been provided to the PRA under I",
            "as_at_date": "03/08/2015"
          }
        ]
      },
