    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to:",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Related Party Transaction Risk",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must enter into transactions with related parties at market value or on terms no more favourable than would be agreed if the transaction was not with a related party.",
            "as_at_date": "01/02/2014"
          },
          {
            "rule_number": "2.2",
            "summary": "2.1 does not apply to beneficial terms that are part of an overall remuneration package such as favourable interest ",
            "as_at_date": "01/02/2014"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm must establish, implement and maintain effective policies and procedures to identify, evaluate and manage risks arising out of transactions with its related parties.",
            "as_at_date": "01/02/2014"
          },
          {
            "rule_number": "2.4",
            "summary": "In meeting 2.3, a firm’s policies and procedures on related party transactions must:",
            "as_at_date": "01/02/2014"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must provide the PRA with details on exposures to related parties if requested by the PRA. The details must be provided by the date set by the PRA at the time of the request.",
            "as_at_date": "29/12/2020"
          }
        ]
      }
    ],
    "section_count": 2,
