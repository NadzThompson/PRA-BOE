        "chapter_title": "Operational Resilience Requirements",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must identify its important business services and, where Group Supervision 22.2 applies, its _impor",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "2.2",
            "summary": "A firm must set an impact tolerance for each of:",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "2.3",
            "summary": "The impact tolerance set for each important business service or important group business service must specify the first point at which a disruption to the important business service or _import",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "2.4",
            "summary": "The impact tolerance set for each important business service or important group business services must specify the length of or point in time, in addition to any other relevant metrics, for whic",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must ensure it can remain within its impact tolerance for each important business service in the event of a severe but plausible disruption to its operations.",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "2.6",
            "summary": "A firm must comply with 2.5 within a reasonable time of the rule coming into effect and in any event by no lat",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Strategies, Processes and Systems",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must have in place sound, effective and comprehensive strategies, processes and systems that enable it adequately to:",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "3.2",
            "summary": "The strategies, processes and systems required by 3.1 must be proportionate to the nature, scale and complexity ",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Mapping",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "As part of its obligation under 3.1, a firm must identify and document the necessary people, processes, techno",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Scenario Testing",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "As part of its obligation under 3.1, a firm must carry out regular scenario testing of its ability to remain w",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "5.2",
            "summary": "In carrying out the scenario testing required by 5.1, a firm must identify an appropriate range of adverse cir",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "5.3",
            "summary": "The scenario testing required by 5.1 must be proportionate to the nature, scale and complexity of the firm's a",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Self-Assessment",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "A firm must prepare and regularly update a written self-assessment of its compliance with this Part and, where [Group Supervision 22.2](/pra-rules/group-supervision#5090df25a1b3453a972090e1ade01115 ",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "6.2",
            "summary": "The content and level of detail of a firm’s written self-assessment must be proportionate to the nature, scale and complexity of the firm’s activities and, where applicable, to the activities of t",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "6.3",
            "summary": "A firm must maintain, and be able to provide to the PRA on request, a current version of its written self-assessment, together with all versions produced during the preceding three years.",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Governance",
        "rules": [
          {
            "rule_number": "7.1",
            "summary": "A firm must ensure that its management body approves the important business services and important group business services identified by the firm in compliance with [2.1](/pra-rules/insuranc",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "7.2",
            "summary": "A firm must ensure that its management body approves the impact tolerances set by the firm in compliance with [2.2](/pra-rules/insurance---operational-resilience#2d5f2fcd58c74940a4d350fb15efb6",
            "as_at_date": "31/03/2022"
          },
          {
            "rule_number": "7.3",
            "summary": "A firm must ensure that its management body approves and regularly reviews the self-assessment required by [6.1](/pra-rules/insurance---operational-resilience#9b41cc1534e54c35a6dc56bd2ab39b3f \"6.1",
            "as_at_date": "31/03/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Group Arrangements",
        "rules": [
          {
            "rule_number": "8.1",
            "summary": "Where a firm is a member of a group , the firm must ensure it accounts for any additional risks arising elsewhere in the group that may affect the firm’s ability to comply with [2.5](/pra-ru",
            "as_at_date": "31/03/2022"
          }
        ]
      },
