        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to a CRR firm that receives critical services supporting critical functions if it fulfils any of the following conditions on 1 January of any year:",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part ceases to apply to a CRR firm to which it applies under 1.1 if the firm does not meet any of the conditions in",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "1.3",
            "summary": "1.2 does not prevent this Part applying to a CRR firm on a subsequent occasion if one of the conditions in [1.1](/pra-rule",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "1.4",
            "summary": "A firm must calculate the averages in 1.1 by adding the values it was required to report each time a report was due and di",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "1.5",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Facilitation of Effective Recovery and Resolution Planning",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must ensure the operational arrangements for the critical services it receives facilitate the effective execution of:",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "2.2",
            "summary": "A firm must ensure the operational arrangements for the critical services it receives facilitate the effective planning for and effective taking of actions in the event of:",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm’s operational and financial arrangements must ensure the continuity of the critical services it receives in the event of:",
            "as_at_date": "01/01/2023"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Details of Operational Continuity Arrangements",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must:",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "3.2",
            "summary": "Subject to 3.2A, if a firm receives critical services from another party, it must ensure the agreement governing the pr",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "3.2A",
            "summary": "3.2 does not apply in respect of an excluded agreement or an agreement entered into by a firm with an excluded person.",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "3.3",
            "summary": "If a firm receives critical services from another party, it must ensure that the agreement governing the provision of those critical services is set on arm’s length terms.",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "3.3A",
            "summary": "A firm must ensure that the charging structure for the critical services it receives is predictable and transparent.",
            "as_at_date": "01/01/2023"
          },
          {
            "rule_number": "3.4",
            "summary": "A firm must ensure access by the firm , the service provider and the PRA to the operational assets supporting critical services is not disrupted in the event of a group member being restruct",
            "as_at_date": "01/01/2019"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Group Arrangements for Operational Continuity",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "This chapter applies to a firm that receives critical services from a group provider.",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm must ensure the group provider has a governance and management structure in place that supports the continuity of the provision of critical services to the firm.",
            "as_at_date": "01/01/2019"
          },
          {
            "rule_number": "4.3",
            "summary": "A firm must ensure that in the event of the deterioration in the financial circumstances of another group member the group provider continues to provide critical services to the firm in acco",
            "as_at_date": "01/01/2023"
          }
        ]
      }
