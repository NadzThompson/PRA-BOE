        "chapter_title": "Certification Functions",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "For the purposes of this Part, the following are certification functions :",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "2.2",
            "summary": "A function is only a certification function to the extent that the function relates to a regulated activity carried on by a firm.",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Performance of Certification Functions",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "A firm must take reasonable care to ensure that none of its employees performs a certification function under an arrangement entered into by the firm in relation to the carrying on by the _fir",
            "as_at_date": "10/12/2019"
          },
          {
            "rule_number": "3.2",
            "summary": "A person does not perform a certification function for a firm under 2.1 if the person is performing any _controll",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.3",
            "summary": "To the extent that:",
            "as_at_date": "10/12/2018"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Material Risk Takers",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "This Chapter applies to a firm that falls within 1.1 and is a large firm.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm must identify, in respect of the firm , its employees who are material risk takers.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.3",
            "summary": "A firm must keep its identification of material risk takers pursuant to 4.2 up-to-date.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "4.4",
            "summary": "A firm must keep a record of its reasoning for the identification of material risk takers pursuant to 4.2.",
            "as_at_date": "10/12/2018"
          }
        ]
      },
