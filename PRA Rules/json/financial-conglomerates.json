    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to every firm except:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part does not apply to a firm with respect to a financial conglomerate of which it is a member if the interest of the financial conglomerate in that firm is no more than a participation",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.3",
            "summary": "The rules in 3.2, 4.2 and [Chapter 7](/pra-rul",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.4",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          },
          {
            "rule_number": "1.5",
            "summary": "Unless otherwise defined in this Part, any italicised expression used in this Part and in the CRR or the Solvency II Directive has the same meaning as in the CRR or the Solvency II Directive.",
            "as_at_date": "12/08/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Definition of a Financial Conglomerate",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A financial conglomerate means a consolidation group that is a financial conglomerate when assessed against the decision tree in [Annex 1](/pra-rules/financial-conglomerates#4fcbfeaeda5b4d8fa1e78932",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "A consolidation group is not prevented from being a financial conglomerate because it is part of a wider:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "For the purpose of the definition of financial conglomerate , there are two financial sectors as follows:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "For the purposes of Annex 1:",
            "as_at_date": "12/08/2022"
          },
          {
            "rule_number": "2.5",
            "summary": "In respect of a financial conglomerate in relation to which a financial conglomerate notification has been issued, the figures in [Annex 1](/pra-rules/financial-conglomerates#4fcbfeaeda5b4d8fa1e78",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.6",
            "summary": "The alteration in 2.5 applies to a financial conglomerate only during the period that:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.7",
            "summary": "The calculations referred to in Annex 1 regarding the balance sheet must be made on the basis of the aggregated balance",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.8",
            "summary": "The solvency and capital adequacy requirements referred to in Annex 1 must be calculated in accordance with the provisi",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Capital Adequacy",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "In this Chapter,",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm must at all times have capital resources of such an amount and type that results in the capital resources of the financial conglomerate being adequate.",
            "as_at_date": "12/08/2022"
          },
          {
            "rule_number": "3.3",
            "summary": "A firm must have capital resources of an amount and type that ensures that the conglomerate capital resources of that financial conglomerate at all times equal or exceed its _conglomerate capita",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "3.4",
            "summary": "1. (1) Subject to 3.5, the definitions of conglomerate capital resources and conglomerate capital resources requirement",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "3.5",
            "summary": "If a firm is subject to a requirement that prescribes the capital adequacy calculation by reference to one or other of Parts 1 and 2 of [Annex 2](/pra-rules/financial-conglomerates#f93b60a630ba4c4",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Risk Concentration and Intra-Group Transactions",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "This Chapter applies to a firm that is a member of a financial conglomerate in respect of which a PRA financial conglomerate notification has been issued.",
            "as_at_date": "12/08/2022"
          },
          {
            "rule_number": "4.2",
            "summary": "A firm that is a member of a financial conglomerate in respect of which a financial conglomerate notification has been issued, and that is headed by a mixed financial holding company must ensu",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "4.3",
            "summary": "Table: application of sectoral rules",
            "as_at_date": "12/08/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Asset Management Companies and Alternative Investment Fund Managers",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A firm must treat an asset management company and an alternative investment fund manager that is a member of a financial conglomerate of which that firm is a member:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Third Country Financial Conglomerates",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "This Chapter applies to a firm that is a member of a third country financial conglomerate except:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "6.2",
            "summary": "If a firm is subject to a requirement obliging it to comply with this rule with respect to a third country financial conglomerate of which it is a member, it must comply, with respect to that _t",
            "as_at_date": "12/08/2022"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Risk Systems",
        "rules": [
          {
            "rule_number": "7.1",
            "summary": "This Chapter applies to a firm that is a member of a financial conglomerate in respect of which a financial conglomerate notification has been issued.",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "7.2",
            "summary": "A firm must comply with Group Risk Systems 2.1.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "7.3",
            "summary": "For the purposes of 7.2, the risk management processes referred to in [Group Risk Systems 2.1](/pra-rules/group-risk-system",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "7.4",
            "summary": "For the purposes of 7.2, the internal control mechanisms referred to in [Group Risk Systems 2.1](/pra-rules/group-risk-syst",
            "as_at_date": "01/01/2016"
          }
        ]
