        "chapter_title": "Conduct Standards",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Individual Conduct Standard 1: You must act with integrity.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "Individual Conduct Standard 2: You must act with due skill, care and diligence.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.3",
            "summary": "Individual Conduct Standard 3: You must be open and co-operative with the FCA , the PRA and other regulators.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.4",
            "summary": "Senior Manager Conduct Standard 1: You must take reasonable steps to ensure that the business of the firm for which you are responsible is controlled effectively.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.5",
            "summary": "Senior Manager Conduct Standard 2: You must take reasonable steps to ensure that the business of the firm for which you are responsible complies with the relevant requirements and standards of the _",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.6",
            "summary": "Senior Manager Conduct Standard 3: You must take reasonable steps to ensure that any delegation of your responsibilities is to an appropriate person and that you oversee the discharge of the delegat",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.7",
            "summary": "Senior Manager Conduct Standard 4: You must disclose appropriately any information of which the FCA or the PRA would reasonably expect to have notice.",
            "as_at_date": "10/12/2018"
          },
          {
            "rule_number": "3.8",
