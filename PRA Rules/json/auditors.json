        "chapter_title": "Appointment of Auditors",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must:",
            "as_at_date": "22/12/2023"
          },
          {
            "rule_number": "2.2",
            "summary": "Where a firm that is not under an obligation to appoint an auditor imposed by an enactment other than FSMA fails to appoint an auditor within 28 days of a vacancy arising, the PRA may appoint ",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm must comply with and is bound by the terms on which an auditor has been appointed by the PRA.",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Auditors’ Qualifications",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Before a firm appoints an auditor, it must take reasonable steps to ensure that the auditor:",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "3.2",
            "summary": "A firm must not appoint as auditor a person who is disqualified under Part XXII of FSMA (Auditors and Actuaries) from acting as an auditor either for that firm or for a relevant class of _firm",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "3.3",
            "summary": "A firm must take reasonable steps to ensure that an auditor, which it is planning to appoint or has appointed, provides information to the PRA about the auditor's qualifications, skills, experienc",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Auditors' Independence",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A firm must take reasonable steps to ensure that the auditor which it appoints is independent of the firm.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "4.2",
            "summary": "If a firm becomes aware at any time that its auditor is not independent of the firm , it must take reasonable steps to ensure that it has an auditor independent of the firm. The firm must noti",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Firms' Cooperation with their Auditors",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "A firm must cooperate with its auditor in the discharge of the auditor’s duties under this Part. In complying with this rule, and in each case subject to section 413 of FSMA (Protected items):",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "5.2",
            "summary": "A firm must take reasonable steps to ensure that:",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Notification of Matters Raised by Auditors",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "A firm must notify the PRA if the firm expects, or knows, that the auditor will qualify the report on the audited annual financial statements or include any emphasis of matter.",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Duties of Auditors",
        "rules": [
          {
            "rule_number": "7.1",
            "summary": "An auditor of a firm must cooperate with the PRA in the discharge of its functions under any relevant legislation.",
            "as_at_date": "25/01/2016"
          },
          {
            "rule_number": "7.2",
            "summary": "An auditor of a firm must give a skilled person appointed by the firm or appointed by the PRA in respect of the firm all assistance that person reasonably requires.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "7.3",
            "summary": "An auditor of a firm must be independent of the firm when performing duties in respect of that firm.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "7.4",
            "summary": "An auditor of a firm must take reasonable steps to be satisfied that no conflict of interest exists in respect of that firm from which bias may reasonably be inferred. The auditor must take approp",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "7.5",
            "summary": "An auditor must notify the PRA without delay if the auditor:",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "7.6",
            "summary": "In the circumstances set out in 7.5, the auditor must notify the PRA without delay:",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Written Reports by Auditors to the PRA",
        "rules": [
          {
            "rule_number": "8.1",
            "summary": "This Chapter applies in relation to annual reports and accounts with an accounting reference date on or after 1 November 2016 but [8.3](/pra-rules/auditors#3b40ef7f9941402383aa2f696ae93577 \"8.3\\(2",
            "as_at_date": "07/03/2019"
          },
          {
            "rule_number": "8.2",
            "summary": "Unless otherwise stated, this Chapter applies to an auditor of a firm that:",
            "as_at_date": "07/03/2019"
          },
          {
            "rule_number": "8.3",
            "summary": "An auditor must provide annually a written report to the PRA in relation to:",
            "as_at_date": "07/03/2019"
          },
          {
            "rule_number": "8.3A",
            "summary": "But an auditor is not required to report in relation to the audited annual report and accounts of the firm’s ultimate parent undertaking if the auditor is not also the auditor of the _ultimate p",
            "as_at_date": "07/03/2019"
          },
          {
            "rule_number": "8.4",
            "summary": "The report in 8.3 must:",
            "as_at_date": "07/03/2019"
          },
          {
            "rule_number": "8.5",
            "summary": "An auditor must consult with the PRA in advance of preparing the report.",
            "as_at_date": "25/01/2016"
          },
          {
            "rule_number": "8.6",
            "summary": "A firm must cooperate with its auditors in preparing the report.",
            "as_at_date": "25/01/2016"
          }
        ]
      }
    ],
