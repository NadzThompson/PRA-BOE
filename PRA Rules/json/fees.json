            "rule_number": "3.5",
            "summary": "The periodic fees payable by:",
            "as_at_date": "01/03/2019"
          },
          {
            "rule_number": "3.6",
            "summary": "The following requirements apply to all firms whose activities give rise to periodic fees , other than firms which pay only a flat rate of fee:",
            "as_at_date": "01/07/2022"
          },
          {
            "rule_number": "3.7",
            "summary": "A firm in its first fee year pays periodic fees based on its projected valuation for the first twelve months of its new business as follows:",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.8",
            "summary": "3.9 applies only to firms in the deposit acceptors fee block (A1), the general insurance fee block (A3) or the _life insurance fee block",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.9",
            "summary": "Subject to 3.10, where in:",
            "as_at_date": ""
          },
          {
            "rule_number": "3.10",
            "summary": "Except in the circumstances to which 3.9 applies, firms in their second fee year or any subsequent fee year after receiving a new or exten",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.11",
            "summary": "The following modifications to periodic fees will apply:",
            "as_at_date": "01/07/2022"
          },
          {
            "rule_number": "3.12",
            "summary": "Where:",
            "as_at_date": "01/03/2018"
          },
          {
            "rule_number": "3.13",
            "summary": "If a firm makes an application to cancel or reduce the scope of its Part 4A permission before the start of a fee year, and if the cancellation or reduction in scope takes effect on or before 31 May of",
            "as_at_date": "02/07/2025"
          },
          {
            "rule_number": "3.14",
            "summary": "Subject to 3.13, if, after the start of the fee year, a firm applies to cancel its Part 4A permission or if a new business activity or event which h",
            "as_at_date": "02/07/2025"
          },
          {
            "rule_number": "3.15",
            "summary": "The due date for payment of periodic fees is as follows:",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.16",
            "summary": "A fee payer need not pay a periodic fee on the due date for payment under the relevant provision of 3 if that date falls during a period d",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.17",
            "summary": "Fee-payers must comply with directions from the PRA or its collection agent as to payment of periodic fees arising from any variance between budgeted and actual AFR or any corrections to the",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.18",
            "summary": "[Deleted.]",
            "as_at_date": "01/07/2019"
          },
          {
