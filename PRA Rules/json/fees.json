          {
            "rule_number": "4.3",
            "summary": "Regulatory transaction fees incurred by a firm remain payable even if an application is withdrawn. Regulatory transaction fees once received by the PRA , or by the collection agent on its ",
            "as_at_date": "01/03/2016"
          },
          {
