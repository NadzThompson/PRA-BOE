    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part, unless otherwise stated, applies to every firm and every person required to pay a fee to the PRA.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Obligation to Pay Fees",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "All fees must be paid in full and without deduction on the due date for payment.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "The due date for payment of:",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "As permitted by paragraphs 31(7) and 35 of Schedule 1ZB of FSMA , the PRA may take all steps and seek all remedies available to a creditor to recover, as a debt due to the PRA , any fee or other",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "The PRA may take regulatory action in relation to non-payment of fees in addition to, or instead of, any steps taken or remedies pursued under [2.3](/pra-rules/fees#8fc472dcdacb424e9ae8c9effd898413 ",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.5",
            "summary": "Fee-payers must comply with directions, whether in an invoice, form, notice or otherwise, of the collection agent when acting in that capacity on behalf of the PRA.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.6",
            "summary": "Subject to 2.8, a fee payer who does not pay the full amount of a fee by the due date for payment will incur late payment interest on an",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.7",
            "summary": "The PRA will not charge interest on late payment interest.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "2.8",
            "summary": "Late payment interest does not apply to regulatory transaction fees and special project fees.",
            "as_at_date": "01/03/2016"
          },
          {
