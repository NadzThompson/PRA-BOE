      {
        "chapter_number": "",
        "chapter_title": "Special Project Fee for Restructuring",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "In the circumstances described in this Chapter, a firm may be required to pay a special project fee for restructuring in addition to the other fees that it pays.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.1A",
            "summary": "In this Chapter “ firm ” includes an FCA authorised firm seeking to vary its Part 4A permission to include a PRA regulated activity.",
            "as_at_date": "01/07/2022"
          },
          {
            "rule_number": "5.2",
            "summary": "An SPF for restructuring becomes payable by a firm if it engages, or prepares to engage, in activity which involves it undertaking or making arrangements with a view to any of the following:",
            "as_at_date": "08/07/2017"
          },
          {
            "rule_number": "5.3",
            "summary": "No SPF for restructuring is payable if the transaction only involves the firm seeking to raise capital within the group to which it belongs.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.4",
            "summary": "An SPF for restructuring may also be payable by a firm if:",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.5",
            "summary": "The PRA and the FCA will levy separate SPFs for restructuring and may do so in relation to the same event or circumstance.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.6",
            "summary": "SPFs for restructuring, once paid, are non-refundable.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.7",
            "summary": "The SPF for restructuring is calculated as follows:",
            "as_at_date": "02/07/2025"
          },
          {
            "rule_number": "5.8",
            "summary": "The due date for payment of an SPF for restructuring is 30 days from the date of each invoice from the PRA to the firm.",
            "as_at_date": "01/07/2019"
          },
          {
            "rule_number": "5.9",
            "summary": "The obligation to pay an SPF for restructuring is ongoing. There is no limit to the number of times that the PRA may invoice a firm for the SPF for restructuring in relation to the same events o",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "5.10",
            "summary": "The SPF for restructuring is a single fee which may be payable under both 5.2 and [5.4](/pra-rules/fees#8c94404f4df7481a888a67d3eb4b39b0 \"5.",
            "as_at_date": "01/03/2016"
          }
        ]
      }
