        "chapter_title": "Periodic Fees",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Periodic fees are payable in respect of each PRA fee year by any person who is, or becomes, a firm during the fee year.",
            "as_at_date": "01/03/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "The amount payable depends upon the fee block to which the firm has been allocated. Firms falling into more than one fee block pay periodic fees in relation to each, other than firms falli",
            "as_at_date": "01/07/2019"
          },
          {
            "rule_number": "3.3",
            "summary": "Periodic fees payable by firms in any fee year will be the sum of the following (so far as applicable to them):",
            "as_at_date": "02/07/2025"
          },
          {
            "rule_number": "3.4",
            "summary": "The tariff bases and valuation points referred to in 3.3 (3)(a) are:",
            "as_at_date": ""
          },
