    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to all firms.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "01/01/2026"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Fundamental Rules",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Fundamental Rule 1: A firm must conduct its business with integrity.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.2",
            "summary": "Fundamental Rule 2: A firm must conduct its business with due skill, care and diligence.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.3",
            "summary": "Fundamental Rule 3: A firm must act in a prudent manner.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.4",
            "summary": "Fundamental Rule 4: A firm must at all times maintain adequate financial resources.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.5",
            "summary": "Fundamental Rule 5: A firm must have effective risk strategies and risk management systems.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.6",
            "summary": "Fundamental Rule 6: A firm must organise and control its affairs responsibly and effectively.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.7",
            "summary": "Fundamental Rule 7: A firm must deal with its regulators in an open and cooperative way and must disclose to the PRA appropriately anything relating to the firm of which the PRA would reason",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "2.8",
            "summary": "Fundamental Rule 8: A firm must prepare for resolution so, if the need arises, it can be resolved in an orderly manner with a minimum disruption of critical services.",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Restrictions",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "[Deleted.]",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "3.2",
            "summary": "[Deleted.]",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "3.3",
            "summary": "The Fundamental Rules apply with respect to the carrying on of:",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "3.4",
            "summary": "Fundamental Rules 3, 4, 5, 6, 8 and (in so far as it relates to disclosing to the PRA) 7 (and this chapter) also:",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "3.5",
            "summary": "The Fundamental Rules apply with respect to activities wherever they are carried on.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "3.6",
            "summary": "Where Fundamental Rule 7 refers to regulators, this means, in addition to the PRA , other regulators with recognised jurisdiction in relation to regulated activities , whether in the UK or abr",
            "as_at_date": "19/06/2014"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Transitional Provisions",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "Each rule in the Principles for Businesses module of the PRA Handbook continues to apply in relation to any act or omission before the date on which this Part came into force.",
            "as_at_date": "19/06/2014"
          },
          {
            "rule_number": "4.2",
            "summary": "Anything done, or having effect as done, under or for the purposes of any rule in the Principles for Businesses module of the PRA Handbook has effect after the date on which this Part came into fo",
            "as_at_date": "19/06/2014"
          }
        ]
      }
    ],
