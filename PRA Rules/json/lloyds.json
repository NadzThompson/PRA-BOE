          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Lloyd’s Members’ Compensation Scheme",
        "rules": [
          {
            "rule_number": "13.1",
            "summary": "This Chapter applies to the Society.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "13.2",
            "summary": "The Society must maintain byelaws establishing appropriate and effective arrangements to compensate individual members and former members who were individual members if underwriting agents",
            "as_at_date": "01/01/2016"
          }
        ]
      }
