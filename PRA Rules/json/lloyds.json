      },
      {
        "chapter_number": "",
        "chapter_title": "Special Provisions for Lloyd’s",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Neither the Society nor managing agents may permit a member to carry on any insurance business , except as a participant on one or more syndicates.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "The Society must ensure that all participants in the Lloyd’s market are made aware of their obligations under the Solvency II Firms Sector of the PRA Ru",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "The Society must establish and maintain effective arrangements to monitor and manage risk arising from:",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Approved Reinsurance to Close",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Notwithstanding that the liability of a reinsured member to a policyholder is unaffected by an approved reinsurance to close for the purposes of the [Solvency II Firms](/pra-rules/sii-firms \"Sol",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Provision of Information by Managing Agents",
        "rules": [
          {
            "rule_number": "4.1",
            "summary": "A managing agent must, as soon as possible, give the Society any information the managing agent has concerning material risks to funds at Lloyd’s or central assets.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "4.2",
            "summary": "A managing agent need not comply with 4.1 if the managing agent knows that the Society already has the relevant information.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Insurance Receivables to Be Carried to Trust Funds",
        "rules": [
          {
            "rule_number": "5.1",
            "summary": "The Society must take all reasonable steps to ensure that each member :",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "5.2",
            "summary": "The Society must carry all amounts it receives on behalf of any member in respect of that member’s insurance business to the appropriate Lloyd’s trust fund.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "5.3",
            "summary": "A managing agent must carry all amounts it receives on behalf of any member in respect of that member’s insurance business to the appropriate Lloyd’s trust fund.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "5.4",
            "summary": "In complying with 5.1 to 5.3, the Society and managing agents must take all ",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Amendments to Byelaws, Trust Deeds and Standard Form Letters of Credit and Guarantees",
        "rules": [
          {
            "rule_number": "6.1",
            "summary": "The Society must, as soon as it is practical to do so, notify the PRA of its intention to approve the form of any new Lloyd’s trust deed.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "6.2",
            "summary": "The Society must, as soon as it is practical to do so, notify the PRA of its intention to make any amendment which may alter the meaning or effect of any byelaw , including:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "6.3",
            "summary": "The Society must provide the PRA with full details of:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "6.4",
            "summary": "The Society must consult interested parties in relation to any new Lloyd’s trust deed and in relation to any amendment falling within [6.2](/pra-rules/lloyds#2bb2722dc482481e8316484f388c4aca \"6.2\"",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "6.5",
            "summary": "The information provided to the PRA by the Societ y under 6.3 must include:",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "The Central Fund",
        "rules": [
          {
            "rule_number": "7.1",
            "summary": "The directions in this Chapter are given under section 318 of FSMA (Exercise of powers through Council) for the purpose of achieving the objective specified, as required by section 318(2) of FSMA.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "7.2",
            "summary": "The directions given in this Chapter are given in relation to the exercise of the powers by the Society in respect of the Central Fund and are given with a view to achieving the objective of ensur",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "7.3",
            "summary": "The Society must, in the exercise of its powers to make payments from the Central Fund or to provide other forms of financial assistance from the Central Fund , ensure that in calculating and de",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Capacity Transfer Market",
        "rules": [
          {
            "rule_number": "8.1",
            "summary": "The Society must make appropriate byelaws governing conduct in the capacity transfer market.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Former Underwriting Members",
        "rules": [
          {
            "rule_number": "9.1",
            "summary": "The Society must ensure that sections 320 to 322 of FSMA (Former underwriting members, Requirements imposed under section 320, Rules applicable to former underwriting members) are drawn to the att",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "9.2",
            "summary": "The Society must require any person , other than a body corporate , ceasing to be an underwriting member on or after 1 December 2001 to:",
            "as_at_date": "01/01/2016"
          }
        ]
      },
