    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "If either Condition A or Condition B is met, this Part applies to a firm with a Part 4A permission that includes entering into a regulated mortgage contract as lender, except:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part applies to an overseas firm only in relation to activities carried on from an establishment in the UK.",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.3",
            "summary": "A firm that is a parent undertaking must ensure that a subsidiary undertaking , which meets Condition A or Condition B, complies with the requirements of this Part in relation to activities carr",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.4",
            "summary": "1.3 does not apply in relation to a subsidiary undertaking that:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.5",
            "summary": "Condition A is that in the set of four consecutive quarters ending on 30 June 2014, the firm has entered into regulated mortgage contracts under which the total credit provided is or exceeds £",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.6",
            "summary": "Where Condition A is met this Part applies from 1 October 2014.",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.7",
            "summary": "Condition B is that during both of two consecutive sets of four quarters the firm has entered into regulated mortgage contracts under which the total credit provided in each set of four _quart",
            "as_at_date": "11/07/2025"
          },
          {
            "rule_number": "1.8",
            "summary": "Where Condition B is met, this Part applies from the start of the second quarter following the end of the final quarter relevant to the determination that the firm meets Condition B.",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.9",
            "summary": "This Part ceases to apply (until Condition A or Condition B is met) if during both of two consecutive sets of four quarters :",
            "as_at_date": "11/07/2025"
          },
          {
            "rule_number": "1.10",
            "summary": "In this chapter two consecutive sets of four quarters means:",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "1.11",
            "summary": "In this Part the following definitions apply:",
            "as_at_date": ""
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "High Loan to Income Allowance",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Unless 2.3 or 2.4 apply, a firm must ensure that by the end of each _quarter",
            "as_at_date": "27/02/2017"
          },
          {
            "rule_number": "2.2",
            "summary": "A firm that is part of a group may allocate all or part of its high loan to income allowance to any member of the group.",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "2.3",
            "summary": "A firm that has allocated any part of its high loan to income allowance to another member of the group must ensure that the number of high loan to income mortgage contracts it enters into in the",
            "as_at_date": "27/02/2017"
          },
          {
            "rule_number": "2.4",
            "summary": "A firm that is part of a group must ensure that the number of high loan to income mortgage contracts it enters into in the relevant period does not exceed the amount specified in [2.1](/pra-ru",
            "as_at_date": "27/02/2017"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must keep a record of any part of a high loan to income allowance it has allocated or received.",
            "as_at_date": "01/10/2014"
          },
          {
            "rule_number": "2.6",
            "summary": "In this chapter, a high loan to income allowance is the number of high loan to income mortgage contracts a firm may enter into in the relevant period in compliance with [2.1](/pra-rules/housing#",
            "as_at_date": "27/02/2017"
          }
        ]
      }
    ],
