    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Unless otherwise stated, this Part applies to a CRR firm , and a CRR consolidation entity :",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.1A",
            "summary": "This Part does not apply to a firm with respect to the carrying on of benchmarking activities except to the extent that they transpose an EU instrument.",
            "as_at_date": "29/06/2018"
          },
          {
            "rule_number": "1.1B",
            "summary": "1. (1) A firm must comply with this Part on an individual basis.",
            "as_at_date": "17/09/2021"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "23/10/2025"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Record Keeping",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must arrange for orderly records to be kept of its business and internal organisation, including all services, activities and transactions undertaken by it, which must be sufficient to enable",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "2.1A",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.1B",
            "summary": "[Deleted]",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.2",
            "summary": "A firm must retain all records kept by it under this Part in relation to its MiFID business for a period of at least five years.",
            "as_at_date": "03/01/2018"
          },
          {
            "rule_number": "2.3",
            "summary": "[Deleted.]",
            "as_at_date": "03/01/2018"
          },
          {
            "rule_number": "2.4",
            "summary": "A firm must retain the records kept by it under this Part in a medium that allows the information to be stored in a way which is accessible for future reference by the PRA, and in such a form and mann",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.5",
            "summary": "A firm must keep at least the organisational records as appropriate to the nature of its activities. The list of organisational records is without prejudice to any other record-keeping obligations ari",
            "as_at_date": "23/10/2025"
          },
          {
            "rule_number": "2.6",
            "summary": "A firm must keep written records of any policies and procedures which it is required to maintain pursuant to the requirements of the regulatory system relating to its MiFID business.",
            "as_at_date": "23/10/2025"
          }
        ]
      }
    ],
