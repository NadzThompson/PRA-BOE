        "chapter_number": "",
        "chapter_title": "Restriction of Business",
        "rules": [
          {
            "rule_number": "12.1",
            "summary": "A third country branch undertaking except a pure reinsurer must not carry on any commercial business other than insurance business and activities directly arising from that business.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "12.2",
            "summary": "A third country branch undertaking that is a pure reinsurer must not carry on any business other than the business of reinsurance and related operations.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Worldwide Financial Resources",
        "rules": [
          {
            "rule_number": "13.1",
            "summary": "A third country branch undertaking must maintain adequate worldwide financial resources, to ensure that there is no significant risk that its liabilities cannot be met as they fall due.",
