        "chapter_title": "Application",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "Subject to 1.2, this Part applies to a UK Solvency II firm carrying on with-profits insurance business.",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part does not apply to with-profits insurance business that consists of effecting contracts of insurance or carrying out contracts of insurance that are Holloway sickness policies.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
