        "chapter_number": "",
        "chapter_title": "Conduct Standards",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Conduct Standard 1: You must act with integrity.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "Conduct Standard 2: You must act with due skill, care and diligence.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "Conduct Standard 3: You must be open and co-operative with the FCA , the PRA and other regulators.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.4",
            "summary": "Conduct Standard 4: You must take reasonable steps to ensure that the business of the firm for which you are responsible is controlled effectively.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.5",
            "summary": "Conduct Standard 5: You must take reasonable steps to ensure that the business of the firm for which you are responsible complies with the relevant requirements and standards of the _regulatory syst",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.6",
            "summary": "Conduct Standard 6: You must take reasonable steps to ensure that any delegation of your responsibilities is to an appropriate person and that you oversee the discharge of the delegated responsibili",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.7",
            "summary": "Conduct Standard 7: You must disclose appropriately any information of which the FCA or the PRA would reasonably expect to have notice.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.8",
            "summary": "Conduct Standard 8: When exercising your responsibilities, you must pay due regard to the interests of current and potential future policyholders in ensuring the provision by the firm of an approp",
            "as_at_date": "07/03/2016"
          }
        ]
      }
    ],
