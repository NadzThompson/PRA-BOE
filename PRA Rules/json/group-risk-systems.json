    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "This Part applies to a CRR firm that is a member of a group save that 2.3 applies to an Article 109 undertaking.",
            "as_at_date": "29/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "This Part does not apply to a firm in relation to the regulated activity of bidding in emissions auctions (article 24A of the Regulated Activities Order) where it is carried on by way of busines",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "1.3",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.4",
            "summary": "Unless otherwise defined in this Part, any italicised expression used in this Part and in the CRR has the same meaning as in the CRR.",
            "as_at_date": "01/01/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Group Systems and Controls",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "A firm must:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "The internal control mechanisms referred to in 2.1 must include:",
            "as_at_date": "01/01/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "An Article 109 undertaking must comply with 2.1(2) in relation to any UK consolidation group or non-UK sub-group of which it",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "2.4",
            "summary": "A CRR firm that is a subsidiary of a mixed-activity holding company must ensure that the risk management processes and internal control mechanisms referred to in [2.1](/pra-rules/group-risk-syst",
            "as_at_date": "01/01/2016"
          }
        ]
      }
    ],
