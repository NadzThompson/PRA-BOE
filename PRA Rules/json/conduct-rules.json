    "sections": [
      {
        "chapter_number": "",
        "chapter_title": "Application and Definitions",
        "rules": [
          {
            "rule_number": "1.1",
            "summary": "1. (1) This Part applies to every function a _person (P) performs in relation to a firm _(A) that is:",
            "as_at_date": "31/12/2020"
          },
          {
            "rule_number": "1.2",
            "summary": "In this Part, the following definitions shall apply:",
            "as_at_date": "07/11/2017"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Individual Conduct Rules",
        "rules": [
          {
            "rule_number": "2.1",
            "summary": "Individual Conduct Rule 1 : You must act with integrity.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.2",
            "summary": "Individual Conduct Rule 2: You must act with due skill, care and diligence.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "2.3",
            "summary": "Individual Conduct Rule 3 : You must be open and co-operative with the FCA , the PRA and other regulators.",
            "as_at_date": "07/03/2016"
          }
        ]
      },
      {
        "chapter_number": "",
        "chapter_title": "Senior Manager Conduct Rules",
        "rules": [
          {
            "rule_number": "3.1",
            "summary": "Senior Manager Conduct Rule 1: You must take reasonable steps to ensure that the business of the firm for which you are responsible is controlled effectively.",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.2",
            "summary": "Senior Manager Conduct Rule 2 : You must take reasonable steps to ensure that the business of the firm for which you are responsible complies with the relevant requirements and standards of the ",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.3",
            "summary": "Senior Manager Conduct Rule 3 : You must take reasonable steps to ensure that any delegation of your responsibilities is to an appropriate person and that you oversee the discharge of the delega",
            "as_at_date": "07/03/2016"
          },
          {
            "rule_number": "3.4",
            "summary": "Senior Manager Conduct Rule 4: You must disclose appropriately any information of which the FCA or PRA would reasonably expect notice.",
            "as_at_date": "07/03/2016"
          }
        ]
      }
    ],
